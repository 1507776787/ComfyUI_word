      "widgets_values": [
        "<theme name=\"orange_glass\" />\n<footer text=\"NovaFlow 橙色科技版 | 第 {page}/{total} 页 | {date}\" />\n\n<slide>\n  <layout name=\"default\" />\n  <background color=\"#FFF7ED\" />\n  <title style=\"font-size:44;color:#7C2D12;text-align:居中;\">NovaFlow AI Studio</title>\n\n  <card x=\"0.8\" y=\"0.8\" width=\"1.1\" height=\"1.1\" bg=\"#FFE4D1\" border=\"#FDBA74\" rounded=\"true\" radius=\"0.45\" shadow=\"true\" />\n  <card x=\"11.0\" y=\"5.9\" width=\"0.9\" height=\"0.9\" bg=\"#FFD6B3\" border=\"#FB923C\" rounded=\"true\" radius=\"0.45\" shadow=\"true\" />\n\n  <section x=\"1.4\" y=\"2.0\" width=\"10.0\" height=\"3.9\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.24\" gap=\"0.14\" shadow=\"true\" rounded=\"true\" radius=\"0.08\">\n    <badge text=\"RELEASE 2.0\" bg=\"#EA580C\" color=\"#FFFFFF\" shadow=\"true\" />\n    <h2 style=\"font-size:24;color:#7C2D12\">智能内容生产与分发中台</h2>\n    <divider color=\"#FDBA74\" />\n    <p style=\"font-size:16;color:#9A3412\">统一生成 Word/PPT、统一下载链接、统一智能体调用协议。</p>\n    <button text=\"进入演示\" bg=\"#F97316\" color=\"#FFFFFF\" shadow=\"true\" />\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"comparison\" />\n  <background color=\"#FFF7ED\" />\n  <title style=\"font-size:34;color:#7C2D12;\">模块能力总览</title>\n\n  <section region=\"left\" x=\"1.0\" y=\"1.4\" width=\"5.1\" height=\"5.2\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.2\" gap=\"0.12\" shadow=\"true\">\n    <h2 style=\"font-size:21;color:#7C2D12\">核心引擎</h2>\n    <icon name=\"doc\" text=\"Word 自动生成引擎\" color=\"#C2410C\" />\n    <icon name=\"chart\" text=\"PPT 富组件渲染器\" color=\"#C2410C\" />\n    <icon name=\"link\" text=\"下载链接回传链路\" color=\"#C2410C\" />\n    <icon name=\"rocket\" text=\"智能体工作流编排\" color=\"#C2410C\" />\n    <spacer height=\"0.08\" />\n    <callout level=\"info\" title=\"特点\" body=\"纯 HTML 驱动，无需外部图片素材。\" title-color=\"#9A3412\" body-color=\"#431407\" bg=\"#FFF7ED\" border=\"#FDBA74\" />\n  </section>\n\n  <section region=\"right\" x=\"6.3\" y=\"1.4\" width=\"5.1\" height=\"5.2\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.2\" gap=\"0.12\" shadow=\"true\">\n    <h2 style=\"font-size:21;color:#7C2D12\">状态面板</h2>\n    <card title=\"任务成功率\" body=\"98.9%&#10;持续稳定\" bg=\"#FFF7ED\" border=\"#FED7AA\" title-color=\"#7C2D12\" body-color=\"#431407\" height=\"1.2\" />\n    <card title=\"平均耗时\" body=\"5.4s&#10;P95: 8.0s\" bg=\"#FFF7ED\" border=\"#FED7AA\" title-color=\"#7C2D12\" body-color=\"#431407\" height=\"1.2\" />\n    <card title=\"下载成功率\" body=\"99.3%&#10;内网直链可用\" bg=\"#FFF7ED\" border=\"#FED7AA\" title-color=\"#7C2D12\" body-color=\"#431407\" height=\"1.2\" />\n    <button text=\"查看实时监控\" bg=\"#EA580C\" color=\"#FFFFFF\" shadow=\"true\" />\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"default\" />\n  <background color=\"#FFF7ED\" />\n  <title style=\"font-size:34;color:#7C2D12;\">数据看板</title>\n\n  <section x=\"1.0\" y=\"1.5\" width=\"10.8\" height=\"2.1\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.18\" gap=\"0.08\" shadow=\"true\">\n    <badge text=\"KPI LIVE\" bg=\"#FB923C\" color=\"#FFFFFF\" />\n    <p style=\"font-size:15;color:#9A3412\">核心指标实时刷新，支持自动导出周报。</p>\n    <button text=\"同步数据\" bg=\"#F97316\" color=\"#FFFFFF\" />\n  </section>\n\n  <section x=\"1.0\" y=\"3.9\" width=\"10.8\" height=\"2.7\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.18\" gap=\"0.1\" shadow=\"true\">\n    <table\n      columns=\"指标,当前值,目标,状态\"\n      rows=\"生成成功率,98.9%,>=98.5%,达标;平均耗时,5.4s,<=7.0s,达标;下载成功率,99.3%,>=99.0%,达标;模板覆盖率,81%,>=80%,达标\"\n      header-bg=\"#FFE4D1\"\n      stripe-bg=\"#FFFFFF\"\n      border=\"#FDBA74\"\n      header-color=\"#7C2D12\"\n      text-color=\"#431407\" />\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"comparison\" />\n  <background color=\"#FFF7ED\" />\n  <title style=\"font-size:34;color:#7C2D12;\">趋势与风险</title>\n\n  <section region=\"left\" x=\"1.0\" y=\"1.5\" width=\"5.1\" height=\"5.1\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.2\" gap=\"0.12\" shadow=\"true\">\n    <chart type=\"bar\" title=\"效率提升(%)\" data=\"Word:62,PPT:58,下载链路:91,人工介入减少:47\" bar-color=\"#F97316\" />\n    <chart type=\"progress\" title=\"整体健康度\" data=\"健康度:93\" bar-color=\"#EA580C\" />\n  </section>\n\n  <section region=\"right\" x=\"6.3\" y=\"1.5\" width=\"5.1\" height=\"5.1\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.2\" gap=\"0.12\" shadow=\"true\">\n    <callout level=\"success\" title=\"稳定项\" body=\"核心链路稳定，无明显抖动。\" title-color=\"#166534\" body-color=\"#431407\" />\n    <callout level=\"warn\" title=\"风险项\" body=\"高峰并发下排队时长上升。\" title-color=\"#92400E\" body-color=\"#431407\" />\n    <callout level=\"error\" title=\"优化项\" body=\"复杂页面内容有溢出风险，需模板约束。\" title-color=\"#B91C1C\" body-color=\"#431407\" />\n    <button text=\"导出风险清单\" bg=\"#EA580C\" color=\"#FFFFFF\" />\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"default\" />\n  <background color=\"#FFF7ED\" />\n  <title style=\"font-size:34;color:#7C2D12;text-align:居中;\">目录与路线图</title>\n\n  <section x=\"1.1\" y=\"1.6\" width=\"10.6\" height=\"2.3\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.2\" gap=\"0.1\" shadow=\"true\">\n    <toc />\n  </section>\n\n  <section x=\"1.1\" y=\"4.2\" width=\"10.6\" height=\"2.2\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.2\" gap=\"0.1\" shadow=\"true\">\n    <h2 style=\"font-size:21;color:#7C2D12\">下一步计划</h2>\n    <ul>\n      <li style=\"font-size:15;color:#431407\">扩展行业模板（医疗/教育/电商）</li>\n      <li style=\"font-size:15;color:#431407\">增强自动排版避免出框</li>\n      <li style=\"font-size:15;color:#431407\">智能体提示词规范化输出</li>\n    </ul>\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"default\" />\n  <background color=\"#FFF7ED\" />\n  <title style=\"font-size:42;color:#7C2D12;text-align:居中;\">Thanks</title>\n\n  <section x=\"2.0\" y=\"2.3\" width=\"8.8\" height=\"3.0\" bg=\"#FFFFFFCC\" border=\"#FDBA74\" padding=\"0.22\" gap=\"0.12\" shadow=\"true\">\n    <badge text=\"READY\" bg=\"#EA580C\" color=\"#FFFFFF\" />\n    <p style=\"font-size:18;color:#431407;text-align:居中;\">已支持多主题预设与外置主题配置，可持续扩展风格。</p>\n    <button text=\"生成下一版方案\" bg=\"#F97316\" color=\"#FFFFFF\" shadow=\"true\" />\n  </section>\n</slide>"
