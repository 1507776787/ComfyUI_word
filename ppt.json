        "<theme name=\"modern_dark\" />\n<footer text=\"深色测试集 | 第 {page}/{total} 页 | {date}\" />\n\n<slide>\n  <layout name=\"default\" />\n  <background color=\"#0F172A\" />\n  <title style=\"font-size:44;color:#F8FAFC;text-align:居中;\">NovaFlow 深色主题测试</title>\n  <section x=\"1.0\" y=\"2.0\" width=\"10.8\" height=\"3.8\" bg=\"#1E293B\" border=\"#334155\" padding=\"0.22\" gap=\"0.14\">\n    <badge text=\"DARK MODE\" bg=\"#1D4ED8\" color=\"#DBEAFE\" />\n    <h2 style=\"font-size:24;color:#FFFFFF;\">目标：验证白字、居中、不出画</h2>\n    <divider color=\"#334155\" />\n    <p style=\"font-size:18;color:#F8FAFC;\">本套示例全部组件使用深色底 + 高对比文字，便于检查可读性。</p>\n    <button text=\"开始检查\" bg=\"#22D3EE\" color=\"#0F172A\" />\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"comparison\" />\n  <background color=\"#0F172A\" />\n  <title style=\"font-size:34;color:#F8FAFC;\">卡片文字颜色测试</title>\n  <section region=\"left\" x=\"1.0\" y=\"1.5\" width=\"5.1\" height=\"5.0\" bg=\"#1E293B\" border=\"#334155\" padding=\"0.18\" gap=\"0.12\">\n    <card title=\"请求量\" body=\"今日 14,280&#10;周环比 +21%\" bg=\"#0F2238\" border=\"#1D4ED8\" title-color=\"#FFFFFF\" body-color=\"#FFFFFF\" height=\"1.35\" />\n    <card title=\"成功率\" body=\"98.9%&#10;目标 >= 98.5%\" bg=\"#0F2E2A\" border=\"#10B981\" title-color=\"#FFFFFF\" body-color=\"#FFFFFF\" height=\"1.35\" />\n    <card title=\"耗时\" body=\"平均 5.4s&#10;P95 8.1s\" bg=\"#2B1E12\" border=\"#F59E0B\" title-color=\"#FFFFFF\" body-color=\"#FFFFFF\" height=\"1.35\" />\n  </section>\n  <section region=\"right\" x=\"6.3\" y=\"1.5\" width=\"5.1\" height=\"5.0\" bg=\"#1E293B\" border=\"#334155\" padding=\"0.18\" gap=\"0.12\">\n    <callout level=\"info\" title=\"说明\" body=\"这里验证 callout 的标题和正文都可强制白字。\" title-color=\"#FFFFFF\" body-color=\"#FFFFFF\" />\n    <callout level=\"success\" title=\"通过标准\" body=\"文字清晰、无发灰、无溢出。\" title-color=\"#FFFFFF\" body-color=\"#FFFFFF\" />\n    <button text=\"继续下一页\" bg=\"#4F46E5\" color=\"#FFFFFF\" />\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"default\" />\n  <background color=\"#0F172A\" />\n  <title style=\"font-size:34;color:#F8FAFC;\">表格文字颜色测试</title>\n  <section x=\"1.0\" y=\"1.5\" width=\"10.8\" height=\"5.0\" bg=\"#1E293B\" border=\"#334155\" padding=\"0.2\" gap=\"0.12\">\n    <table\n      columns=\"模块,状态,说明\"\n      rows=\"HTMLToPPT|稳定|多主题多组件支持;下载链路|稳定|返回可访问下载链接;智能体调用|进行中|模板变量化输出;自动清理|规划中|按天归档策略\"\n      header-bg=\"#23324A\"\n      stripe-bg=\"#162235\"\n      border=\"#334155\"\n      header-color=\"#FFFFFF\"\n      text-color=\"#FFFFFF\" />\n    <button text=\"导出测试报告\" bg=\"#22C55E\" color=\"#FFFFFF\" />\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"comparison\" />\n  <background color=\"#0F172A\" />\n  <title style=\"font-size:34;color:#F8FAFC;\">图表与列表测试</title>\n  <section region=\"left\" x=\"1.0\" y=\"1.5\" width=\"5.1\" height=\"5.0\" bg=\"#1E293B\" border=\"#334155\" padding=\"0.18\" gap=\"0.12\">\n    <chart type=\"bar\" title=\"效率提升(%)\" data=\"Word:62,PPT:58,下载链路:91,人工介入减少:47\" bar-color=\"#22D3EE\" />\n    <p style=\"font-size:15;color:#FFFFFF;\">图表标签使用高亮色，文字保持白色增强对比。</p>\n  </section>\n  <section region=\"right\" x=\"6.3\" y=\"1.5\" width=\"5.1\" height=\"5.0\" bg=\"#1E293B\" border=\"#334155\" padding=\"0.18\" gap=\"0.12\">\n    <h2 style=\"font-size:22;color:#FFFFFF;\">检查项</h2>\n    <ul>\n      <li style=\"font-size:16;color:#FFFFFF;\">标题是否居中且清晰</li>\n      <li style=\"font-size:16;color:#FFFFFF;\">卡片正文是否为白字</li>\n      <li style=\"font-size:16;color:#FFFFFF;\">表格正文是否仍然白字</li>\n      <li style=\"font-size:16;color:#FFFFFF;\">组件是否有越界现象</li>\n    </ul>\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"default\" />\n  <background color=\"#0F172A\" />\n  <title style=\"font-size:34;color:#F8FAFC;text-align:居中;\">目录回看</title>\n  <section x=\"1.0\" y=\"1.7\" width=\"10.8\" height=\"4.8\" bg=\"#1E293B\" border=\"#334155\" padding=\"0.2\" gap=\"0.1\">\n    <toc />\n  </section>\n</slide>\n\n<slide>\n  <layout name=\"default\" />\n  <background color=\"#0F172A\" />\n  <title sty